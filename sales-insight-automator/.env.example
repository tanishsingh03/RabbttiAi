# ─── Application ────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── AI Service (e.g., OpenAI) ───────────────────────────────────────────────
# TODO: Replace with your chosen AI provider credentials.
OPENAI_API_KEY=your_openai_api_key_here
# GEMINI_API_KEY=your_google_gemini_api_key_here

# ─── Email Service (e.g., SendGrid / Nodemailer SMTP) ────────────────────────
# TODO: Replace with your chosen email provider credentials.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM="Sales Insight Bot <noreply@example.com>"

# SENDGRID_API_KEY=your_sendgrid_api_key_here
